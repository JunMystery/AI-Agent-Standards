*metrics-actual.csv
*tracking-*.csv

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Node/Python
node_modules/
__pycache__/
*.pyc

# Temp
*.tmp
temp/
.temp/

implementation_plan.md